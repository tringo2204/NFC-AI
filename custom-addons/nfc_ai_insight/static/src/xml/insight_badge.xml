<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <!-- ── Popover Panel with tabs ──────────────────────────────────────── -->
  <t t-name="nfc_ai_insight.InsightPanel">
    <div class="nfc-ai-panel-wrap">

      <!-- Header -->
      <div class="nfc-ai-panel-header">
        <span><i class="fa fa-robot me-1"/>NFC AI Insight</span>
        <div class="nfc-ai-meta-inline">
          <span><b><t t-esc="props.decision.data_points"/>đ/c</b></span>
          <span t-if="props.decision.cached" class="nfc-ai-cache-pill">⚡Cache</span>
        </div>
      </div>

      <!-- Tabs -->
      <div class="nfc-ai-tabs">
        <button t-attf-class="nfc-ai-tab {{ state.tab === 'overview' ? 'active' : '' }}"
                t-on-click="() => setTab('overview')">Tổng quan</button>
        <button t-if="props.decision.price_context and props.decision.price_context.chart_data and props.decision.price_context.chart_data.length > 1"
                t-attf-class="nfc-ai-tab {{ state.tab === 'chart' ? 'active' : '' }}"
                t-on-click="() => setTab('chart')">📈 Biểu đồ</button>
        <button t-if="props.decision.price_context and props.decision.price_context.supplier_compare and props.decision.price_context.supplier_compare.length"
                t-attf-class="nfc-ai-tab {{ state.tab === 'suppliers' ? 'active' : '' }}"
                t-on-click="() => setTab('suppliers')">🏭 NCC</button>
      </div>

      <div class="nfc-ai-panel-body">

        <!-- ── Tab: Tổng quan ── -->
        <t t-if="state.tab === 'overview'">
          <p class="nfc-ai-msg"><t t-esc="props.decision.message"/></p>
          <p t-if="props.decision.suggestion" class="nfc-ai-sugg">
            <i class="fa fa-lightbulb-o me-1"/>
            <t t-esc="props.decision.suggestion"/>
          </p>
          <t t-if="props.decision.price_context">
            <div class="nfc-ai-stats-grid">
              <div t-if="props.decision.price_context.avg_price" class="nfc-ai-stat">
                <span class="nfc-ai-stat-label">TB 6T</span>
                <span class="nfc-ai-stat-value"><t t-esc="fmt(props.decision.price_context.avg_price)"/>đ</span>
              </div>
              <div t-if="props.decision.price_context.min_price" class="nfc-ai-stat">
                <span class="nfc-ai-stat-label">Thấp nhất</span>
                <span class="nfc-ai-stat-value" style="color:#198754"><t t-esc="fmt(props.decision.price_context.min_price)"/>đ</span>
              </div>
              <div t-if="props.decision.price_context.max_price" class="nfc-ai-stat">
                <span class="nfc-ai-stat-label">Cao nhất</span>
                <span class="nfc-ai-stat-value" style="color:#dc3545"><t t-esc="fmt(props.decision.price_context.max_price)"/>đ</span>
              </div>
              <div t-if="props.decision.price_context.suggested_price" class="nfc-ai-stat nfc-ai-stat--highlight">
                <span class="nfc-ai-stat-label">Đề xuất</span>
                <span class="nfc-ai-stat-value"><t t-esc="fmt(props.decision.price_context.suggested_price)"/>đ</span>
              </div>
            </div>
            <div t-if="props.decision.price_context.best_supplier" class="nfc-ai-best-supplier">
              <i class="fa fa-trophy me-1" style="color:#f59e0b"/>
              NCC tốt nhất: <b><t t-esc="props.decision.price_context.best_supplier"/></b>
              <t t-if="props.decision.price_context.best_supplier_price">
                — <b><t t-esc="fmt(props.decision.price_context.best_supplier_price)"/>đ</b>
              </t>
            </div>
            <t t-if="props.decision.price_context.recent_history and props.decision.price_context.recent_history.length">
              <div class="nfc-ai-history-title">Lịch sử gần nhất</div>
              <table class="nfc-ai-history-table">
                <tr t-foreach="props.decision.price_context.recent_history" t-as="row" t-key="row_index">
                  <td class="nfc-ai-history-date"><t t-esc="row.date"/></td>
                  <td class="nfc-ai-history-supplier"><t t-esc="row.supplier"/></td>
                  <td class="nfc-ai-history-price"><b><t t-esc="fmt(row.price)"/>đ</b></td>
                </tr>
              </table>
            </t>
          </t>
          <div class="nfc-ai-meta">
            <span>Tin cậy: <b><t t-esc="confidenceLabel(props.decision.confidence)"/></b></span>
          </div>
        </t>

        <!-- ── Tab: Biểu đồ Sparkline ── -->
        <t t-if="state.tab === 'chart'">
          <div class="nfc-ai-chart-title">Lịch sử giá 12 tháng</div>
          <PriceSparkline
            data="props.decision.price_context.chart_data"
            currentPrice="props.decision.price_context.avg_price"
            width="336"
            height="80"
          />
          <div class="nfc-ai-chart-legend">
            <span class="nfc-ai-legend-line"/>  Giá mua
            <span class="nfc-ai-legend-dash"/> Giá TB
          </div>
        </t>

        <!-- ── Tab: So sánh NCC ── -->
        <t t-if="state.tab === 'suppliers'">
          <div class="nfc-ai-history-title">So sánh nhà cung cấp</div>
          <table class="nfc-ai-supplier-table">
            <thead>
              <tr>
                <th>Nhà cung cấp</th>
                <th>TB giá</th>
                <th>Thấp nhất</th>
                <th>Đơn</th>
              </tr>
            </thead>
            <tbody>
              <tr t-foreach="props.decision.price_context.supplier_compare" t-as="s" t-key="s_index"
                  t-attf-class="{{ s_index === 0 ? 'nfc-ai-best-row' : '' }}">
                <td>
                  <i t-if="s_index === 0" class="fa fa-star me-1" style="color:#f59e0b"/>
                  <t t-esc="s.supplier"/>
                </td>
                <td><b><t t-esc="fmt(s.avg_price)"/>đ</b></td>
                <td style="color:#198754"><t t-esc="fmt(s.min_price)"/>đ</td>
                <td><t t-esc="s.count"/></td>
              </tr>
            </tbody>
          </table>
        </t>

      </div>

      <!-- Feedback -->
      <div t-if="props.logId" class="nfc-ai-panel-footer">
        <button class="btn btn-sm btn-outline-success"   t-on-click="() => feedback('accepted')">✓ Chấp nhận</button>
        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => feedback('ignored')">Bỏ qua</button>
        <button class="btn btn-sm btn-outline-warning"   t-on-click="() => feedback('overridden')">Ghi đè</button>
      </div>
    </div>
  </t>

  <!-- ── Badge nhỏ (click → mở Popover) ──────────────────────────────── -->
  <t t-name="nfc_ai_insight.InsightBadge">
    <span>
      <button t-if="props.loading" class="nfc-ai-badge nfc-ai-badge--loading" disabled="disabled">
        <i class="fa fa-spinner fa-spin fa-fw"/> AI
      </button>
      <button t-elif="props.decision"
              t-ref="badge"
              t-attf-class="nfc-ai-badge nfc-ai-badge--{{ props.decision.level }}"
              t-on-click.stop="openPanel">
        <i t-attf-class="fa {{ levelIcon(props.decision.level) }} fa-fw"/>
        <t t-esc="levelLabel(props.decision.level)"/>
        <span t-if="props.decision.deviation_pct" class="nfc-ai-deviation">
          (<t t-esc="formatDev(props.decision.deviation_pct)"/>)
        </span>
      </button>
    </span>
  </t>

  <!-- ── Field wrapper: field gốc + badge cạnh nhau ───────────────────── -->
  <t t-name="nfc_ai_insight.InsightField">
    <div class="nfc-ai-field-wrap">
      <MonetaryField t-if="isMonetary" t-props="props"/>
      <FloatField    t-else="1"        t-props="props"/>
      <InsightBadge
        loading="state.loading"
        decision="state.decision"
        logId="state.logId"
        onFeedback="onFeedback"
      />
    </div>
  </t>

</templates>
