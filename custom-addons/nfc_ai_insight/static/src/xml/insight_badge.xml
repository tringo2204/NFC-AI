<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <!-- ── Badge nhỏ + Panel chi tiết ───────────────────────────────── -->
  <t t-name="nfc_ai_insight.AiBadge">
    <div class="nfc-ai-wrap-relative d-inline-block">

      <!-- Spinner -->
      <button t-if="props.loading"
              class="nfc-ai-badge nfc-ai-badge--loading"
              disabled="disabled">
        <i class="fa fa-spinner fa-spin fa-fw"/> AI
      </button>

      <!-- Badge kết quả -->
      <button t-elif="props.decision"
              t-attf-class="nfc-ai-badge nfc-ai-badge--{{ props.decision.level }}"
              t-on-click.stop="toggle"
              t-att-title="props.decision.message">
        <i t-attf-class="fa {{ levelIcon(props.decision.level) }} fa-fw"/>
        <span t-esc="levelLabel(props.decision.level)"/>
        <span t-if="props.decision.deviation_pct" class="nfc-ai-deviation">
          (<t t-esc="formatDev(props.decision.deviation_pct)"/>)
        </span>
      </button>

      <!-- Panel chi tiết -->
      <div t-if="state.open and props.decision" class="nfc-ai-panel">
        <div class="nfc-ai-panel-header">
          <span>NFC AI Insight</span>
          <i class="fa fa-times" style="cursor:pointer" t-on-click.stop="toggle"/>
        </div>
        <div class="nfc-ai-panel-body">
          <p class="nfc-ai-msg"><t t-esc="props.decision.message"/></p>
          <p t-if="props.decision.suggestion" class="nfc-ai-sugg">
            <i class="fa fa-lightbulb-o me-1"/>
            <t t-esc="props.decision.suggestion"/>
          </p>
          <div class="nfc-ai-meta">
            <span><b><t t-esc="props.decision.data_points"/> giao dịch</b></span>
            <span>Độ tin cậy: <b><t t-esc="confidenceLabel(props.decision.confidence)"/></b></span>
            <span t-if="props.decision.cached" style="color:#0d6efd">⚡ Cache</span>
          </div>
        </div>
        <div t-if="props.logId" class="nfc-ai-panel-footer">
          <button class="btn btn-sm btn-outline-success" t-on-click.stop="() => props.onFeedback('accepted')">✓ Chấp nhận</button>
          <button class="btn btn-sm btn-outline-secondary" t-on-click.stop="() => props.onFeedback('ignored')">Bỏ qua</button>
          <button class="btn btn-sm btn-outline-warning" t-on-click.stop="() => props.onFeedback('overridden')">Ghi đè</button>
        </div>
      </div>
    </div>
  </t>

  <!-- ── InsightField: price_unit gốc + AiBadge bên cạnh ──────────── -->
  <t t-name="nfc_ai_insight.InsightField">
    <div class="nfc-ai-field-wrap">
      <!-- Render field gốc (monetary hoặc float) -->
      <MonetaryField t-if="isMonetary" t-props="props"/>
      <FloatField    t-else="1"        t-props="props"/>

      <!-- AI Badge -->
      <AiBadge
        loading="state.loading"
        decision="state.decision"
        logId="state.logId"
        onFeedback="(action) => onFeedback(action)"
      />
    </div>
  </t>

</templates>
