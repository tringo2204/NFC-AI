<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Sprint 5: AI trên dòng PR — Đơn giá ước tính (cùng widget với PO) -->
  <record id="view_purchase_request_form_ai_insight" model="ir.ui.view">
    <field name="name">purchase.request.form.nfc.ai.insight</field>
    <field name="model">purchase.request</field>
    <field name="inherit_id" ref="nfc_purchase_request.view_purchase_request_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='line_ids']//field[@name='estimated_price']" position="attributes">
        <attribute name="widget">nfc_ai_insight</attribute>
      </xpath>
    </field>
  </record>

</odoo>
