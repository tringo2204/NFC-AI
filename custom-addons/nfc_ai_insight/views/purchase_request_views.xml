<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Sprint 5: AI trên dòng PR — Đơn giá ước tính (cùng widget với PO) -->
  <record id="view_purchase_request_form_ai_insight" model="ir.ui.view">
    <field name="name">purchase.request.form.nfc.ai.insight</field>
    <field name="model">purchase.request</field>
    <field name="inherit_id" ref="nfc_purchase_request.view_purchase_request_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='line_ids']//field[@name='estimated_price']" position="attributes">
        <attribute name="widget">nfc_ai_insight</attribute>
      </xpath>
    </field>
  </record>

  <record id="view_purchase_request_form_executive_summary" model="ir.ui.view">
    <field name="name">purchase.request.form.nfc.executive.summary</field>
    <field name="model">purchase.request</field>
    <field name="inherit_id" ref="nfc_purchase_request.view_purchase_request_form"/>
    <field name="priority">28</field>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="Tóm tắt BGĐ" name="nfc_executive_summary_pr" sequence="3">
          <field name="nfc_executive_summary_html" colspan="2" nolabel="1" readonly="1"/>
        </page>
      </xpath>
    </field>
  </record>

</odoo>
