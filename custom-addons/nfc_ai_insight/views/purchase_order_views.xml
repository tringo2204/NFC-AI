<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    Inject widget="nfc_ai_insight" vào field price_unit
    bên trong inline order_line list của purchase.order form.

    Approach theo ERP AI Platform canvas (Sprint 3):
      - Widget WRAP field gốc (không tạo column riêng)
      - price_unit hiện giá bình thường + badge AI ngay cạnh
      - 0 column picker cần thiết
  -->
  <record id="view_purchase_order_form_ai_insight" model="ir.ui.view">
    <field name="name">purchase.order.form.nfc.ai.insight</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='order_line']//field[@name='price_unit']" position="attributes">
        <attribute name="widget">nfc_ai_insight</attribute>
      </xpath>
    </field>
  </record>

</odoo>
