<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Sprint 3: widget="nfc_ai_insight" trên price_unit trong order_line -->
  <record id="view_purchase_order_form_ai_insight" model="ir.ui.view">
    <field name="name">purchase.order.form.nfc.ai.insight</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='order_line']//field[@name='price_unit']" position="attributes">
        <attribute name="widget">nfc_ai_insight</attribute>
      </xpath>
    </field>
  </record>

</odoo>
